# Consistent formatting across editors and file types.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown uses two trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false

# Vendored PHP artifacts and golden fixtures are byte-exact — don't touch them.
[priv/php/**]
trim_trailing_whitespace = false
insert_final_newline = false

[test/fixtures/**]
trim_trailing_whitespace = false
insert_final_newline = false
